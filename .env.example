# RideFlow — environment variables
# Copy to .env and edit for tuning experiments. Defaults reflect docs/03-tuning.md
# baselines; experiments (E-P1..E-X5) flip individual values.

# ----------------------------------------------------------------------------
# Kafka broker
# ----------------------------------------------------------------------------
KAFKA_DEFAULT_REPLICATION_FACTOR=3
KAFKA_MIN_INSYNC_REPLICAS=2
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_LOG_SEGMENT_BYTES=104857600
KAFKA_AUTO_CREATE_TOPICS_ENABLE=false

# ----------------------------------------------------------------------------
# Kafka producer (ingest-api) — write path triangle
# ----------------------------------------------------------------------------
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_LINGER_MS=0
KAFKA_PRODUCER_COMPRESSION_TYPE=none
KAFKA_PRODUCER_MAX_IN_FLIGHT_REQUESTS=5
KAFKA_PRODUCER_ENABLE_IDEMPOTENCE=true
KAFKA_PRODUCER_BUFFER_MEMORY=33554432

# ----------------------------------------------------------------------------
# Kafka consumer (flink, query-api) — read path
# ----------------------------------------------------------------------------
KAFKA_CONSUMER_FETCH_MIN_BYTES=1
KAFKA_CONSUMER_FETCH_MAX_WAIT_MS=500
KAFKA_CONSUMER_MAX_POLL_RECORDS=500
KAFKA_CONSUMER_MAX_POLL_INTERVAL_MS=300000
KAFKA_CONSUMER_SESSION_TIMEOUT_MS=45000
KAFKA_CONSUMER_AUTO_OFFSET_RESET=latest
KAFKA_CONSUMER_ENABLE_AUTO_COMMIT=false

# ----------------------------------------------------------------------------
# Flink
# ----------------------------------------------------------------------------
FLINK_PARALLELISM_DEFAULT=4
FLINK_TASKMANAGER_NUMBER_TASK_SLOTS=2
FLINK_TASKMANAGER_MEMORY_PROCESS_SIZE=1728m
FLINK_STATE_BACKEND=rocksdb
FLINK_PIPELINE_MAX_PARALLELISM=128
FLINK_EXECUTION_CHECKPOINTING_INTERVAL=10000
FLINK_EXECUTION_CHECKPOINTING_MODE=AT_LEAST_ONCE
FLINK_EXECUTION_CHECKPOINTING_TIMEOUT=600000
FLINK_EXECUTION_CHECKPOINTING_MIN_PAUSE=5000
FLINK_EXECUTION_CHECKPOINTING_UNALIGNED=true

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_MAXMEMORY=
REDIS_MAXMEMORY_POLICY=noeviction
REDIS_APPENDONLY=no

# ----------------------------------------------------------------------------
# Schema Registry
# ----------------------------------------------------------------------------
SCHEMA_REGISTRY_URL=http://schema-registry:8081
SCHEMA_REGISTRY_COMPATIBILITY=BACKWARD

# ----------------------------------------------------------------------------
# Postgres (source-of-truth + CDC source)
# ----------------------------------------------------------------------------
POSTGRES_DB=rideflow
POSTGRES_USER=rideflow
POSTGRES_PASSWORD=rideflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Simulator
# ----------------------------------------------------------------------------
SIM_EPS=10
SIM_DRIVERS=50
SIM_PCT_LATE=0.0
SIM_PCT_DUP=0.0
SIM_PCT_MALFORMED=0.0
INGEST_API_URL=http://ingest-api:8000

# ----------------------------------------------------------------------------
# Service URLs (set automatically inside compose network)
# ----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka-0:9092,kafka-1:9092,kafka-2:9092
REDIS_URL=redis://redis:6379/0
